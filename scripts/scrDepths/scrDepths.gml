 * 2. GUI Depths
 */

// // // 
//
// Draw Depths
//
// // //

// Hack: depth = DEPTH_WORLD - 10
#macro 	DEPTH_WORLD 		-10
#macro	DEPTH_GROUND		0

// // //
//
// GUI Depths
//
// // //

#macro 	DEPTH_GUI_FADER 	-100
#macro 	DEPTH_GUI_DIALOGUE	-110
#macro	DEPTH_GUI_PAUSE		-120

